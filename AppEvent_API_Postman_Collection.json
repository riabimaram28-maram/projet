{
  "info": {
    "name": "AppEvent API - Complete Testing Suite",
    "description": "Collection complète pour tester les 3 sprints de l'API AppEvent",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8082",
      "type": "string"
    },
    {
      "key": "adminToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "userToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "userId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "🔐 Sprint 1: Connexion",
      "item": [
        {
          "name": "1. Connexion Admin",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"admin@iset.tn\",\n    \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('adminToken', response.token);",
                  "    pm.test('Admin login successful', () => {",
                  "        pm.expect(response.token).to.be.a('string');",
                  "        pm.expect(response.roles).to.include('ADMIN');",
                  "    });",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "2. Test Accès Non Autorisé",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/users/profile",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "profile"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Should return 401 Unauthorized', () => {",
                  "    pm.expect(pm.response.code).to.equal(401);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "3. Accès avec Token Admin",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/users/profile",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "profile"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Should return 200 OK', () => {",
                  "    pm.expect(pm.response.code).to.equal(200);",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.email).to.equal('admin@iset.tn');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "📝 Sprint 2: Inscription",
      "item": [
        {
          "name": "1. Inscription Nouvel Utilisateur",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"firstname\": \"Jean\",\n    \"lastname\": \"Dupont\",\n    \"email\": \"jean.dupont@email.com\",\n    \"password\": \"password123\",\n    \"confirmPassword\": \"password123\",\n    \"phone\": \"12345678\",\n    \"role\": \"PARTICIPANT\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('userId', response.id.toString());",
                  "    pm.test('User registration successful', () => {",
                  "        pm.expect(response.id).to.be.a('number');",
                  "        pm.expect(response.email).to.equal('jean.dupont@email.com');",
                  "    });",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "2. Test Validation Mots de Passe",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"firstname\": \"Marie\",\n    \"lastname\": \"Martin\",\n    \"email\": \"marie.martin@email.com\",\n    \"password\": \"password123\",\n    \"confirmPassword\": \"password456\",\n    \"phone\": \"87654321\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Should return 400 Bad Request', () => {",
                  "    pm.expect(pm.response.code).to.equal(400);",
                  "    pm.expect(pm.response.text()).to.include('mots de passe ne correspondent pas');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "3. Connexion Nouvel Utilisateur",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"jean.dupont@email.com\",\n    \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('userToken', response.token);",
                  "    pm.test('User login successful', () => {",
                  "        pm.expect(response.token).to.be.a('string');",
                  "        pm.expect(response.roles).to.include('PARTICIPANT');",
                  "    });",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "👨‍💼 Sprint 3: Gestion Admin",
      "item": [
        {
          "name": "1. Lister Tous les Utilisateurs",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/users/all",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "all"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Should return 200 OK', () => {",
                  "    pm.expect(pm.response.code).to.equal(200);",
                  "    const response = pm.response.json();",
                  "    pm.expect(response).to.be.an('array');",
                  "    pm.expect(response.length).to.be.at.least(1);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "2. Voir Statistiques",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/users/statistics",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "statistics"
              ]
            }
          }
        },
        {
          "name": "3. Mettre à Jour Utilisateur",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"firstname\": \"Jean Michel\",\n    \"lastname\": \"Dupont\",\n    \"email\": \"jean.michel.dupont@email.com\",\n    \"phone\": \"98765432\",\n    \"role\": \"ORGANISATEUR\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users/{{userId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "{{userId}}"
              ]
            }
          }
        },
        {
          "name": "4. Changer Rôle",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"role\": \"PARTICIPANT\",\n    \"reason\": \"Changement de rôle suite à demande utilisateur\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users/{{userId}}/role",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "{{userId}}",
                "role"
              ]
            }
          }
        },
        {
          "name": "5. Réinitialiser Mot de Passe",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"jean.michel.dupont@email.com\",\n    \"newPassword\": \"newpassword123\",\n    \"confirmPassword\": \"newpassword123\",\n    \"adminReason\": \"Réinitialisation suite à oubli du mot de passe\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users/reset-password",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "reset-password"
              ]
            }
          }
        },
        {
          "name": "6. Désactiver Utilisateur",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/users/{{userId}}/toggle-status",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "{{userId}}",
                "toggle-status"
              ]
            }
          }
        },
        {
          "name": "7. Réactiver Utilisateur",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/users/{{userId}}/toggle-status",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "{{userId}}",
                "toggle-status"
              ]
            }
          }
        },
        {
          "name": "8. Supprimer Utilisateur",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/users/{{userId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "{{userId}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "🚨 Tests de Sécurité",
      "item": [
        {
          "name": "1. Tentative Suppression Admin",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/users/1",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "1"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Should return 400 Bad Request', () => {",
                  "    pm.expect(pm.response.code).to.equal(400);",
                  "    pm.expect(pm.response.text()).to.include('Impossible de supprimer un administrateur');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "2. Accès Non Autorisé Admin Functions",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{userToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/users/all",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "all"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Should return 403 Forbidden', () => {",
                  "    pm.expect(pm.response.code).to.equal(403);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
